{
  "name": "@mcp-contracts/cli",
  "version": "0.1.0",
  "description": "CLI tool for capturing and diffing MCP tool schemas",
  "type": "module",
  "bin": {
    "mcpdiff": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mcp-contracts/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cli-table3": "^0.6.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": ["mcp", "model-context-protocol", "cli", "schema", "diff", "mcpdiff"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-contracts/mcp-contracts",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}

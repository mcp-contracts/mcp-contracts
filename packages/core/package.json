{
  "name": "@mcp-contracts/core",
  "version": "0.1.0",
  "description": "Snapshot, diff, and classify MCP tool schema changes",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": ["mcp", "model-context-protocol", "schema", "diff", "contract", "validation"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-contracts/mcp-contracts",
    "directory": "packages/core"
  }
}
